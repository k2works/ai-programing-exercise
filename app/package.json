{
  "name": "tdd-javascript-tutorial",
  "version": "1.0.0",
  "description": "テスト駆動開発から始めるJavaScript入門 - ソフトウェア開発の三種の神器を準備する",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:silent": "SILENT_TESTS=true jest",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "echo 'ESLintは未設定です。必要に応じて追加してください。'",
    "clean": "rm -rf coverage/ node_modules/",
    "setup": "npm install",
    "tdd": "jest --watch --verbose",
    "demo": "node src/index.js && echo '\n=== FizzBuzz Demo ===' && node -e \"import('./src/fizzbuzz.js').then(m => console.log(new m.FizzBuzz().generateSequence(20).join(', ')))\""
  },
  "keywords": [
    "tdd",
    "javascript",
    "test-driven-development",
    "tutorial"
  ],
  "author": "k2works",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}
