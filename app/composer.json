{
    "name": "ai-programming-exercise/fizzbuzz-php",
    "description": "テスト駆動開発によるFizzBuzz実装（PHP版）",
    "type": "project",
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "scripts": {
        "test": "phpunit",
        "test-watch": "phpunit --watch"
    }
}
