[MASTER]
jobs=1
unsafe-load-any-extension=no
extension-pkg-whitelist=

[MESSAGES CONTROL]
# Disable specific warnings
disable=
    C0103,  # Invalid name
    C0111,  # Missing docstring
    R0903,  # Too few public methods
    W0613,  # Unused argument
    C2401,  # Non-ASCII name (for Japanese test method names)
    W0201,  # Attribute defined outside __init__ (for pytest setup_method)
    C0415,  # Import outside toplevel (for imports in test methods)
    W0611,  # Unused import

[REPORTS]
output-format=text
reports=no
score=yes

[REFACTORING]
max-nested-blocks=5
never-returning-functions=sys.exit

[BASIC]
good-names=i,j,k,ex,Run,_,x,y,z
bad-names=foo,bar,baz,toto,tutu,tata

[FORMAT]
max-line-length=88
indent-string='    '
expected-line-ending-format=LF

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=no

[VARIABLES]
init-import=no
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+?$)|dummy|^ignored_|^unused_

[CLASSES]
defining-attr-methods=__init__,__new__,setUp
valid-classmethod-first-arg=cls
valid-metaclass-classmethod-first-arg=mcs

[DESIGN]
max-args=5
ignored-argument-names=_.*
max-locals=15
max-returns=6
max-branches=12
max-statements=50
max-parents=7
max-attributes=7
min-public-methods=2
max-public-methods=20
max-bool-expr=5
